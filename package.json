{
  "name": "@nestjs/cqrs",
  "version": "11.0.3",
  "description": "A lightweight CQRS module for Nest framework (node.js)",
  "license": "MIT",
  "url": "https://github.com/nestjs/cqrs#readme",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "oxlint src/",
    "prepublish:next": "npm run build",
    "publish:next": "npm publish --access public --tag next",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "prerelease": "npm run build",
    "release": "release-it",
    "prepare": "husky",
    "test:e2e": "vitest run --config vitest.config.e2e.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-angular": "21.0.2",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/testing": "11.1.26",
    "@types/node": "24.13.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxlint": "1.69.0",
    "prettier": "3.8.4",
    "reflect-metadata": "0.2.2",
    "release-it": "20.2.0",
    "rxjs": "7.8.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.2.0"
  },
  "lint-staged": {
    "**/*.{ts,json}": []
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs/cqrs"
  },
  "changelog": {
    "labels": {
      "feature": "Features",
      "bug": "Bug fixes",
      "enhancement": "Enhancements",
      "docs": "Docs",
      "dependencies": "Dependencies",
      "type: code style": "Code style tweaks",
      "status: blocked": "Breaking changes",
      "breaking change": "Breaking changes"
    }
  }
}
